@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>VidaPlena — Iniciar Sesión</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
        }

        /* LADO IZQUIERDO */
        .left-panel {
            width: 55%;
            background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 50%, #40916c 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
            top: -100px; left: -100px;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
            bottom: -80px; right: -80px;
        }

        .brand {
            text-align: center;
            margin-bottom: 50px;
            z-index: 1;
        }

        .brand h1 {
            font-size: 3rem;
            font-weight: 800;
            color: white;
        }

        .brand h1 span { color: #95d5b2; }

        .brand p {
            color: rgba(255,255,255,0.6);
            font-size: 0.8rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-top: 8px;
        }

        .stats {
            display: flex;
            flex-direction: column;
            gap: 16px;
            width: 100%;
            max-width: 340px;
            z-index: 1;
        }

        .stat-card {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 14px;
            padding: 18px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            backdrop-filter: blur(10px);
        }

        .stat-icon {
            width: 44px; height: 44px;
            background: rgba(149,213,178,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .stat-card h3 {
            color: white;
            font-size: 1rem;
            font-weight: 600;
        }

        .stat-card p {
            color: rgba(255,255,255,0.5);
            font-size: 0.78rem;
        }

        /* LADO DERECHO */
        .right-panel {
            width: 45%;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 50px;
        }

        .login-header {
            margin-bottom: 32px;
        }

        .login-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1b4332;
        }

        .login-header p {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 6px;
        }

        .error-box {
            background: #fff5f5;
            border: 1px solid #fed7d7;
            border-radius: 10px;
            padding: 12px 16px;
            color: #c53030;
            font-size: 0.88rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .rol-selector {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 24px;
        }

        .rol-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #4a5568;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .rol-options {
            display: flex;
            gap: 10px;
        }

        .rol-btn {
            flex: 1;
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            background: white;
            cursor: pointer;
            font-size: 0.82rem;
            color: #4a5568;
            transition: all 0.2s;
            text-align: center;
        }

        .rol-btn:hover { border-color: #40916c; color: #2d6a4f; }
        .rol-btn.selected {
            border-color: #2d6a4f;
            background: #d8f3dc;
            color: #1b4332;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            color: #4a5568;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 0.95rem;
            color: #2d3748;
            transition: border-color 0.2s;
            outline: none;
        }

        .form-group input:focus { border-color: #40916c; }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #2d6a4f, #40916c);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #1b4332, #2d6a4f);
            transform: translateY(-1px);
        }

        .footer-text {
            text-align: center;
            margin-top: 30px;
            color: #a0aec0;
            font-size: 0.78rem;
        }

        #rolInput { display: none; }
    </style>
</head>
<body>

<!-- PANEL IZQUIERDO -->
<div class="left-panel">
    <div class="brand">
        <h1>Vida<span>Plena</span></h1>
        <p>Sistema de Gestión Geriátrica</p>
    </div>
    <div class="stats">
        <div class="stat-card">
            <div class="stat-icon">🏠</div>
            <div>
                <h3>Gestión Integral</h3>
                <p>Control total del hogar geriátrico</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🔔</div>
            <div>
                <h3>Alertas en Tiempo Real</h3>
                <p>Monitoreo continuo de residentes</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">💊</div>
            <div>
                <h3>Control de Medicación</h3>
                <p>Trazabilidad completa de tratamientos</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">👨‍👩‍👧</div>
            <div>
                <h3>Portal Familiar</h3>
                <p>Comunicación con familias en tiempo real</p>
            </div>
        </div>
    </div>
</div>

<!-- PANEL DERECHO -->
<div class="right-panel">
    <div class="login-header">
        <h2>Bienvenido</h2>
        <p>Ingresa tus credenciales para continuar</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="error-box">
            <i class="fas fa-exclamation-circle"></i>
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/Account/Login">
        <!-- SELECTOR DE ROL -->
        <div class="rol-selector">
            <div class="rol-label">Rol</div>
            <div class="rol-options">
                <button type="button" class="rol-btn" onclick="seleccionarRol('Administrador', this)">
                    👤 Administrador
                </button>
                <button type="button" class="rol-btn" onclick="seleccionarRol('Enfermero', this)">
                    👩‍⚕️ Enfermería
                </button>
                <button type="button" class="rol-btn" onclick="seleccionarRol('Medico', this)">
                    🩺 Médico
                </button>
            </div>
            <input type="hidden" name="rol" id="rolInput" value=""/>
        </div>

        <div class="form-group">
            <label>Usuario</label>
            <input type="text" name="email" placeholder="correo@ejemplo.com" required/>
        </div>

        <div class="form-group">
            <label>Contraseña</label>
            <input type="password" name="contrasena" placeholder="••••••••" required/>
        </div>

        <button type="submit" class="btn-login">
            Ingresar al Sistema →
        </button>
    </form>

    <div class="footer-text">
        Institución Universitaria Salazar y Herrera · IUSH<br/>
        VidaPlena v1.0 — Hogar Geriátrico
    </div>
</div>

<script>
    function seleccionarRol(rol, btn) {
        document.querySelectorAll('.rol-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        document.getElementById('rolInput').value = rol;
    }
</script>
</body>
</html>