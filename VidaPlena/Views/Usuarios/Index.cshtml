@model IEnumerable<VidaPlena.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 style="color:#1b4332;font-weight:700;">
        <i class="fas fa-users me-2"></i>Gestión de Usuarios
    </h4>
    <a href="/Usuarios/Create" class="btn btn-primary">
        <i class="fas fa-user-plus me-2"></i>Nuevo Usuario
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Género</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>
                            <div style="font-weight:600">@u.Nombre @u.Apellido</div>
                        </td>
                        <td>@u.Email</td>
                        <td>
                            @if (u.Rol == "Administrador")
                            {
                                <span class="badge" style="background:#d8f3dc;color:#1b4332">👤 @u.Rol</span>
                            }
                            else if (u.Rol == "Medico")
                            {
                                <span class="badge" style="background:#d1ecf1;color:#0c5460">🩺 @u.Rol</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#fff3cd;color:#856404">👩‍⚕️ @u.Rol</span>
                            }
                        </td>
                        <td>@(u.Genero == "M" ? "Masculino" : "Femenino")</td>
                        <td>
                            @if (u.Activo == true)
                            {
                                <span class="badge" style="background:#d4edda;color:#155724">Activo</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#f8d7da;color:#721c24">Inactivo</span>
                            }
                        </td>
                        <td>
                            <a href="/Usuarios/Edit/@u.idUsuario" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a href="/Usuarios/Delete/@u.idUsuario" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>