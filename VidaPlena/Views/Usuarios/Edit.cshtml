@model VidaPlena.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 style="color:#1b4332;font-weight:700;">
        <i class="fas fa-user-edit me-2"></i>Editar Usuario
    </h4>
    <a href="/Usuarios" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" action="/Usuarios/Edit">
            <input type="hidden" name="idUsuario" value="@Model.idUsuario"/>
            <input type="hidden" name="FechaCreacion" value="@Model.FechaCreacion"/>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nombre</label>
                    <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" required/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Apellido</label>
                    <input type="text" name="Apellido" class="form-control" value="@Model.Apellido" required/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Email</label>
                    <input type="email" name="Email" class="form-control" value="@Model.Email" required/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Contraseña</label>
                    <input type="password" name="Contrasena" class="form-control" value="@Model.Contrasena" required/>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Rol</label>
                    <select name="Rol" class="form-select" required>
                        @if (Model.Rol == "Administrador") {
                            <option value="Administrador" selected>Administrador</option>
                            <option value="Medico">Médico</option>
                            <option value="Enfermero">Enfermero</option>
                        } else if (Model.Rol == "Medico") {
                            <option value="Administrador">Administrador</option>
                            <option value="Medico" selected>Médico</option>
                            <option value="Enfermero">Enfermero</option>
                        } else {
                            <option value="Administrador">Administrador</option>
                            <option value="Medico">Médico</option>
                            <option value="Enfermero" selected>Enfermero</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Género</label>
                    <select name="Genero" class="form-select" required>
                        @if (Model.Genero == "M") {
                            <option value="M" selected>Masculino</option>
                            <option value="F">Femenino</option>
                        } else {
                            <option value="M">Masculino</option>
                            <option value="F" selected>Femenino</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">ID Hogar</label>
                    <input type="number" name="idHogar" class="form-control" value="@Model.idHogar" required/>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Teléfono</label>
                    <input type="text" name="Telefono" class="form-control" value="@Model.Telefono"/>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Estado</label>
                    <select name="Activo" class="form-select">
                        @if (Model.Activo == true) {
                            <option value="true" selected>Activo</option>
                            <option value="false">Inactivo</option>
                        } else {
                            <option value="true">Activo</option>
                            <option value="false" selected>Inactivo</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
                <a href="/Usuarios" class="btn btn-outline-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>